<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>
        <!-- Database connection -->
        <property name="hibernate.connection.driver_class">com.mysql.cj.jdbc.Driver</property>
        <property name="hibernate.connection.url">jdbc:mysql://localhost:3306/quizzy?serverTimezone=UTC</property>
        <property name="hibernate.connection.username">root</property>
        <property name="hibernate.connection.password"></property>

        <!-- HikariCP connection pool -->
        <property name="hibernate.connection.provider_class">org.hibernate.hikaricp.internal.HikariCPConnectionProvider</property>
        <property name="hibernate.hikari.minimumIdle">5</property>
        <property name="hibernate.hikari.maximumPoolSize">20</property>
        <property name="hibernate.hikari.idleTimeout">300000</property>
        <property name="hibernate.hikari.connectionTimeout">30000</property>

        <!-- MySQL dialect -->
        <property name="hibernate.dialect">org.hibernate.dialect.MySQL8Dialect</property>

        <!-- Schema validation -->
        <property name="hibernate.hbm2ddl.auto">validate</property>

        <!-- Debugging -->
        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.format_sql">true</property>

        <!-- Entity mappings -->
        <mapping class="quizzy.model.User"/>
        <mapping class="quizzy.model.Quiz"/>
        <mapping class="quizzy.model.QuizAttempt"/>
        <mapping class="quizzy.model.Announcement"/>
        <mapping class="quizzy.model.UserAchievement"/>
        <mapping class="quizzy.model.ReportedQuiz"/>

        <mapping class="quizzy.model.question.Question"/>
        <mapping class="quizzy.model.question.TextQuestion"/>
        <mapping class="quizzy.model.question.FillBlankQuestion"/>
        <mapping class="quizzy.model.question.MultipleChoiceQuestion"/>
        <mapping class="quizzy.model.question.PictureQuestion"/>
        <mapping class="quizzy.model.question.Answer"/>
    </session-factory>
</hibernate-configuration>
