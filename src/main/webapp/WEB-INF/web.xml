<?xml version="1.0" encoding="UTF-8"?>

<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ===== M4 Admin ===== -->

    <!-- Admin Authorization Filter -->
    <filter>
        <filter-name>AdminAuthorizationFilter</filter-name>
        <filter-class>quizzy.filter.AdminAuthorizationFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AdminAuthorizationFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>

    <!-- Admin Dashboard -->
    <servlet>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <servlet-class>quizzy.admin.AdminDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <url-pattern>/admin/</url-pattern>
    </servlet-mapping>

    <!-- Announcements CRUD -->
    <servlet>
        <servlet-name>AnnouncementServlet</servlet-name>
        <servlet-class>quizzy.admin.AnnouncementServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AnnouncementServlet</servlet-name>
        <url-pattern>/admin/announcements</url-pattern>
    </servlet-mapping>

    <!-- Moderation Actions -->
    <servlet>
        <servlet-name>ModerationServlet</servlet-name>
        <servlet-class>quizzy.admin.ModerationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ModerationServlet</servlet-name>
        <url-pattern>/admin/moderation</url-pattern>
    </servlet-mapping>

</web-app>